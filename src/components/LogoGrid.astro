---
import { Sparkles, Hexagon, Leaf, Zap, Terminal, RefreshCw, CircleDot, Crosshair, Box, Layers, Gem, Plus } from 'lucide-astro';

interface Props {
  heading?: string;
}

const {
  heading = "Most business websites are liabilities. These businesses don't have that problem. Their websites aren't just nice to look at - they are revenue generating assets.",
} = Astro.props;

const logos = [
  { name: 'Acme Corp', icon: Sparkles },
  { name: 'AlphaWave', icon: Hexagon },
  { name: 'Biosynthesia', icon: Leaf },
  { name: 'Boltshift', icon: Zap },
  { name: 'Command+R', icon: Terminal },
  { name: 'Calescence', icon: RefreshCw },
  { name: 'Capsule', icon: CircleDot },
  { name: 'Clandestine', icon: Crosshair },
  { name: 'Constellation', icon: Box },
  { name: 'ContrastAI', icon: Layers },
  { name: 'Cubekit', icon: Gem },
];
---

<section class="py-20 px-6 bg-surface">
  <div class="max-w-4xl mx-auto text-center mb-12">
    <p class="text-content-light text-base sm:text-lg leading-relaxed italic">
      {heading}
    </p>
  </div>

  <div class="max-w-5xl mx-auto border border-outline rounded-xl overflow-hidden">
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
      {logos.map((logo) => (
        <div class="flex items-center justify-center gap-2.5 px-4 py-5 border-b border-r border-outline last:border-r-0">
          <logo.icon class="w-5 h-5 text-content shrink-0" />
          <span class="text-sm font-semibold text-content whitespace-nowrap">{logo.name}</span>
        </div>
      ))}
      {/* "Your logo" placeholder */}
      <div class="flex items-center justify-center gap-2 px-4 py-5 border-b border-r border-outline last:border-r-0">
        <div class="flex items-center gap-1.5 border border-dashed border-content-lighter rounded-md px-3 py-1.5">
          <Plus class="w-3.5 h-3.5 text-content-lighter" />
          <span class="text-sm text-content-lighter whitespace-nowrap">Your logo</span>
        </div>
      </div>
    </div>
  </div>
</section>
