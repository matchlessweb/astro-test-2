---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  heading?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
  items?: FAQItem[];
}

const {
  heading = 'Frequently Asked Questions',
  description = "Don\u2019t see your question answered here? Reach out to your Blues Fitness Coaches via the form located on the contact page.",
  ctaText = 'Contact Blues Fitness',
  ctaHref = '/contact',
  items = [
    {
      question: 'Why was the BluePrint created?',
      answer: 'The BluePrint was created to provide employees with a comprehensive wellness program that supports physical, mental, and emotional health through structured courses and challenges.',
    },
    {
      question: 'Do I have to participate in Wellness Courses?',
      answer: 'Participation in Wellness Courses is voluntary, but completing courses can contribute to your overall wellness goals and may qualify you for incentives under the Employee Health Plan.',
    },
    {
      question: 'Are all Wellness Courses and Challenges exclusively virtual?',
      answer: 'No, our Wellness Courses and Challenges are offered in a variety of formats including virtual, in-person, and hybrid options to accommodate different preferences and schedules.',
    },
  ],
} = Astro.props;
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
      <!-- Left column -->
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-primary-dark italic leading-tight mb-6">
          {heading}
        </h2>
        <p class="text-content-light text-base leading-relaxed mb-8 max-w-md">
          {description}
        </p>
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center px-8 py-3 bg-primary-dark hover:bg-primary-dark/90 text-white font-medium rounded-lg transition-colors duration-200"
        >
          {ctaText}
        </a>
      </div>

      <!-- Right column: accordion -->
      <div class="flex flex-col">
        {items.map((item, i) => (
          <details
            class:list={['group border-primary-dark/30', i < items.length - 1 && 'border-b']}
          >
            <summary class="flex items-center justify-between gap-4 py-5 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
              <span class="text-lg md:text-xl font-bold text-primary-dark">{item.question}</span>
              <span class="shrink-0 w-7 h-7 flex items-center justify-center text-primary-dark text-2xl font-light transition-transform duration-200 group-open:rotate-45">+</span>
            </summary>
            <div class="pb-5 text-content-light text-base leading-relaxed pr-10">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
