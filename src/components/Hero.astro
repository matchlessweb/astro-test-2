---
import { CircleCheckBig } from 'lucide-astro';

interface Props {
  label?: string;
  title?: string;
  subtitle?: string;
  features?: string[];
  primaryCtaText?: string;
  primaryCtaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  label = '2026 Employee Health Plan',
  title = 'Your health and wellness<br />starts with the <span class="text-primary-dark">Blue</span><span class="text-primary">Print</span>.',
  subtitle = 'The BluePrint is your home base for all things Employee Health Plan.',
  features = ['Educational Courses', 'Fitness Challenges', 'Coaching Programs', 'Journaling Activities'],
  primaryCtaText = 'Wellness Courses',
  primaryCtaHref = '/courses',
  secondaryCtaText = 'Dashboard',
  secondaryCtaHref = '/dashboard',
} = Astro.props;
---

<section class="relative overflow-hidden bg-white">
  <!-- Grid background -->
  <div class="absolute inset-0 opacity-[0.07]" style="background-image: linear-gradient(to right, #94a3b8 1px, transparent 1px), linear-gradient(to bottom, #94a3b8 1px, transparent 1px); background-size: 40px 40px;"></div>

  <!-- Fade edges -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_50%,white_100%)]"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 pt-28 pb-20 text-center">
    <!-- Label -->
    <p class="text-sm md:text-base text-content-light tracking-wide mb-6">
      {label}
    </p>

    <!-- Heading -->
    <h1
      class="text-4xl sm:text-5xl md:text-6xl font-bold text-primary leading-[1.2] tracking-tight mb-6 text-pretty"
      set:html={title}
    />

    <!-- Subtitle -->
    <p class="text-base md:text-lg text-content-light max-w-2xl mx-auto mb-12">
      {subtitle}
    </p>

    <!-- Features row -->
    <div class="inline-flex flex-wrap items-center justify-center gap-x-8 gap-y-4 border border-outline rounded-xl px-8 py-5 mb-10 bg-white/70 backdrop-blur-sm">
      {features.map((feature) => (
        <div class="flex items-center gap-2.5">
          <CircleCheckBig class="w-5 h-5 text-primary shrink-0" />
          <span class="text-sm md:text-base font-medium text-content">{feature}</span>
        </div>
      ))}
    </div>

    <!-- CTA buttons -->
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href={primaryCtaHref}
        class="inline-flex items-center justify-center px-8 py-3.5 bg-primary hover:bg-primary-dark text-white font-semibold rounded-lg transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg"
      >
        {primaryCtaText}
      </a>
      <a
        href={secondaryCtaHref}
        class="inline-flex items-center justify-center px-8 py-3.5 bg-secondary hover:bg-secondary-dark text-white font-semibold rounded-lg transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg"
      >
        {secondaryCtaText}
      </a>
    </div>

    <slot />
  </div>
</section>
