---
interface Props {
  heading?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
  backgroundImage?: string;
}

const {
  heading = 'Explore Wellness Courses',
  description = 'Visit the Wellness Courses page and see all the options available for participation for the 2025 Employee Health Plan.',
  ctaText = 'Explore All Wellness Courses',
  ctaHref = '/courses',
  backgroundImage = 'https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1600&h=600&fit=crop',
} = Astro.props;
---

<section class="relative overflow-hidden">
  <!-- Background image -->
  <img
    src={backgroundImage}
    alt=""
    width={1600}
    height={600}
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
    aria-hidden="true"
  />
  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-[#1e1e2e]/85"></div>

  <!-- Content -->
  <div class="relative z-10 py-24 md:py-32 px-6 text-center max-w-3xl mx-auto">
    <h2 class="text-3xl md:text-5xl lg:text-6xl font-bold text-white italic leading-tight mb-6">
      {heading}
    </h2>
    <p class="text-white/80 text-base md:text-lg leading-relaxed mb-10">
      {description}
    </p>
    <a
      href={ctaHref}
      class="inline-flex items-center justify-center px-10 py-3.5 bg-white hover:bg-white/90 text-content font-semibold rounded-lg transition-colors duration-200"
    >
      {ctaText}
    </a>
  </div>
</section>
