---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
import Hero from '../components/Hero.astro';
import BlueprintBanner from '../components/BlueprintBanner.astro';
import WhatIsBlueprint from '../components/WhatIsBlueprint.astro';
import HowToUse from '../components/HowToUse.astro';
import ExploreWellness from '../components/ExploreWellness.astro';
import FAQ from '../components/FAQ.astro';


import FooterCTA from '../components/FooterCTA.astro';

---

<BaseLayout title="Home">
  <Header />
  
  <main id="main-content">
    <!-- Hero Section -->
    <Hero />
    
    <!-- Blueprint Banner -->
    <BlueprintBanner />
    
    <!-- What is the BluePrint -->
    <WhatIsBlueprint />
    
    <!-- How to Use the BluePrint -->
    <HowToUse />

    <!-- Explore Wellness Courses -->
    <ExploreWellness />

    <!-- FAQ Section -->
    <FAQ />


    


    <!-- Footer CTA -->
    <FooterCTA />
  </main>
  
  <Footer />
</BaseLayout>
