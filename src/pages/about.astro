---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="About Us" description="Learn more about who we are and what we do">
  <main class="py-16 md:py-24 bg-surface">
    <div class="container mx-auto px-4">
      <!-- Hero Section -->
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-content mb-6">
          About Us
        </h1>
        <p class="text-xl text-content-light leading-relaxed">
          We're passionate about creating amazing experiences. Learn more about our story, 
          our mission, and the team behind it all.
        </p>
      </div>

      <!-- Mission Section -->
      <div class="max-w-4xl mx-auto mb-16">
        <div class="bg-surface-alt border border-outline rounded-2xl p-8 md:p-12">
          <h2 class="text-2xl md:text-3xl font-bold text-content mb-4">Our Mission</h2>
          <p class="text-lg text-content-light leading-relaxed">
            Our mission is to deliver exceptional value to our customers through innovation, 
            quality, and dedication. We believe in building lasting relationships and 
            making a positive impact in everything we do.
          </p>
        </div>
      </div>

      <!-- Values Section -->
      <div class="max-w-4xl mx-auto mb-16">
        <h2 class="text-2xl md:text-3xl font-bold text-content mb-8 text-center">Our Values</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-surface-alt border border-outline rounded-xl p-6 text-center">
            <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-content mb-2">Innovation</h3>
            <p class="text-content-light text-sm">We constantly push boundaries and embrace new ideas.</p>
          </div>
          <div class="bg-surface-alt border border-outline rounded-xl p-6 text-center">
            <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-content mb-2">Community</h3>
            <p class="text-content-light text-sm">We build strong relationships with customers and partners.</p>
          </div>
          <div class="bg-surface-alt border border-outline rounded-xl p-6 text-center">
            <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-content mb-2">Excellence</h3>
            <p class="text-content-light text-sm">We strive for quality in everything we create.</p>
          </div>
        </div>
      </div>

      <!-- CTA Section -->
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl font-bold text-content mb-4">Want to learn more?</h2>
        <p class="text-content-light mb-6">Get in touch with us to discuss how we can help you.</p>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-lg transition-colors cursor-pointer no-underline">
          <span class="text-white">Contact Us</span>
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </main>
</PageLayout>
